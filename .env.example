# Censys API credentials (required for network exposure check)
CENSYS_API_ID=
CENSYS_API_SECRET=

# NVD API key (optional — without it CVE lookups are rate-limited to 5 req/30s)
# Get a free key from: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Google Safe Browsing API key (required for safe_browsing check)
# Get from: https://developers.google.com/safe-browsing/v4/get-started
GOOGLE_SAFE_BROWSING_API_KEY=

# Splunk HEC token (required if send_to_splunk = true in settings.yaml)
SPLUNK_HEC_TOKEN=

# Dashboard authentication
# Set both to enable HTTP Basic Auth on the dashboard.
# If either is unset, auth is disabled (this is ONLY for local development, NOT production)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=
